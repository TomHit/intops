{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://apitestops.local/schemas/test_case.schema.json",
  "title": "API Test Case",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "module",
    "test_type",
    "priority",
    "objective",
    "preconditions",
    "test_data",
    "steps",
    "expected_results",
    "api_details",
    "validation_focus",
    "references",
    "needs_review",
    "review_notes"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "module": {
      "type": "string",
      "minLength": 1
    },
    "test_type": {
      "type": "string",
      "enum": ["contract", "schema", "negative", "auth"]
    },
    "priority": {
      "type": "string",
      "enum": ["P0", "P1", "P2", "P3"]
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "preconditions": {
      "type": "array",
      "default": [],
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "test_data": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path_params",
        "query_params",
        "headers",
        "cookies",
        "request_body"
      ],
      "properties": {
        "path_params": {
          "type": "object",
          "default": {}
        },
        "query_params": {
          "type": "object",
          "default": {}
        },
        "headers": {
          "type": "object",
          "default": {}
        },
        "cookies": {
          "type": "object",
          "default": {}
        },
        "request_body": {}
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "expected_results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "api_details": {
      "type": "object",
      "additionalProperties": false,
      "required": ["method", "path"],
      "properties": {
        "method": {
          "type": "string",
          "enum": ["GET", "POST", "PUT", "PATCH", "DELETE", "HEAD", "OPTIONS"]
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "operation_id": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "base_url": {
          "type": "string"
        },
        "full_url_template": {
          "type": "string"
        },
        "full_url_resolved": {
          "type": "string"
        }
      }
    },
    "validation_focus": {
      "type": "array",
      "default": [],
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "references": {
      "type": "array",
      "default": [],
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "needs_review": {
      "type": "boolean"
    },
    "review_notes": {
      "type": "string"
    }
  }
}
